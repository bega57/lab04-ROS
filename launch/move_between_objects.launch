<launch>
  <arg name="model" default="waffle_pi"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find lab4)/worlds/two_objects.world"/>
    <arg name="paused"     value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"        value="true"/>
  </include>

  <param name="robot_description"
         command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
        args="-urdf -model turtlebot3_$(arg model) -x 0.0 -y 0.0 -z 0.0 -param robot_description"/>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>

  <node pkg="lab4" type="camera_node.py"          name="camera_node"          output="screen"/>
  <node pkg="lab4" type="status_publisher.py"     name="status_publisher"     output="screen"/>
  <node pkg="lab4" type="logging_control.py"      name="logging_control"      output="screen"/>
  <node pkg="lab4" type="logger.py"               name="logger"               output="screen"/>
  <node pkg="lab4" type="move_between_objects.py" name="move_between_objects" output="screen"/>
</launch>
